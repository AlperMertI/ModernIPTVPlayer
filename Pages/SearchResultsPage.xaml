<Page
    x:Class="ModernIPTVPlayer.Pages.SearchResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernIPTVPlayer.Pages"
    xmlns:models="using:ModernIPTVPlayer.Models"
    xmlns:stremio="using:ModernIPTVPlayer.Models.Stremio"
    xmlns:controls="using:ModernIPTVPlayer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:ModernIPTVPlayer.Converters"
    mc:Ignorable="d"
    Background="Black">

    <Page.Resources>
        <converters:BoolToVisibleConverter x:Key="BoolToVisibleConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <!-- Grid Panel Template -->
        <ItemsPanelTemplate x:Key="SearchGridPanelTemplate">
            <ItemsWrapGrid Orientation="Horizontal" HorizontalAlignment="Center"/>
        </ItemsPanelTemplate>

        <!-- Result Item Template -->
        <DataTemplate x:Key="SearchResultTemplate" x:DataType="models:IMediaStream">
            <controls:PosterCard Title="{x:Bind Title, Mode=OneWay}" 
                              ImageUrl="{x:Bind PosterUrl, Mode=OneWay}"
                              BadgeText="{x:Bind Rating, Mode=OneWay}"
                              ShowBadge="True"
                              Width="180" Height="265"
                              Margin="0"
                              IsTitleVisible="True"
                              ColorsExtracted="PosterCard_ColorsExtracted"
                              HoverStarted="PosterCard_HoverStarted"
                              HoverEnded="PosterCard_HoverEnded"/>
        </DataTemplate>

        <!-- Shimmer Item Template -->
        <DataTemplate x:Key="ShimmerResultTemplate">
            <controls:ShimmerCard Width="180" Height="265" Margin="4" CornerRadius="12"/>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <!-- Premium Backdrop -->
        <controls:DynamicBackdrop x:Name="BackdropControl" />
        <Rectangle Fill="#20000000" IsHitTestVisible="False"/>

        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Header -->
                <RowDefinition Height="*"/>    <!-- Results -->
            </Grid.RowDefinitions>
        
        <!-- Header -->
        <Grid x:Name="HeaderContainer" Padding="48,64,48,24" VerticalAlignment="Top" Canvas.ZIndex="2000">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="24">
                <!-- Back Button (Using HyperlinkButton for native Hand cursor) -->
                <HyperlinkButton x:Name="BackButton" Click="BackButton_Click" 
                                 Width="44" Height="44" Padding="0" 
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE72B;" FontSize="16" Foreground="White"/>
                </HyperlinkButton>

                <StackPanel VerticalAlignment="Center">
                    <!-- Breadcrumbs -->
                    <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal" Spacing="8" Opacity="0.5" Margin="0,0,0,4">
                        <HyperlinkButton x:Name="RootBreadcrumb" Content="Stremio" Padding="0" FontSize="11" FontWeight="SemiBold" Click="RootBreadcrumb_Click"/>
                        <TextBlock Text="/" FontSize="10" VerticalAlignment="Center" Opacity="0.5"/>
                        <HyperlinkButton x:Name="TypeBreadcrumb" Content="Filmler" Padding="0" FontSize="11" FontWeight="SemiBold" Click="TypeBreadcrumb_Click"/>
                        <StackPanel x:Name="CategoryBreadcrumbArea" Orientation="Horizontal" Visibility="Collapsed" Spacing="8">
                             <TextBlock Text="/" FontSize="10" VerticalAlignment="Center" Opacity="0.5"/>
                             <HyperlinkButton x:Name="CategoryBreadcrumb" Content="Popüler" Padding="0" FontSize="11" FontWeight="SemiBold" Click="CategoryBreadcrumb_Click"/>
                        </StackPanel>
                        
                        <!-- 4th Level: Genre -->
                        <StackPanel x:Name="GenreBreadcrumbArea" Orientation="Horizontal" Visibility="Collapsed" Spacing="8">
                             <TextBlock Text="/" FontSize="10" VerticalAlignment="Center" Opacity="0.5"/>
                             <StackPanel Orientation="Horizontal" Spacing="4">
                                 <TextBlock x:Name="GenreBreadcrumbText" Text="Animation" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                 <HyperlinkButton x:Name="BtnClearGenre" Click="ClearGenre_Click" 
                                                  Padding="4" MinWidth="0" MinHeight="0" VerticalAlignment="Center">
                                     <FontIcon Glyph="&#xE711;" FontSize="8" Foreground="White" Opacity="0.6"/>
                                 </HyperlinkButton>
                             </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    
                    <!-- Title & Badges -->
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitle" Text="Arama Sonuçları" FontSize="28" FontWeight="ExtraBold" Foreground="White" CharacterSpacing="50"/>
                        
                        <!-- Stremio Count -->
                        <Border x:Name="StremioCountBadge" Visibility="Collapsed" Background="#15FFFFFF" BorderBrush="#15FFFFFF" BorderThickness="1" CornerRadius="8" Padding="10,4" VerticalAlignment="Center" Margin="0,4,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="TxtStremioCount" Text="0" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Stremio" FontSize="11" Opacity="0.5" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Border>

                        <!-- IPTV Count -->
                        <Border x:Name="IptvCountBadge" Visibility="Collapsed" Background="{ThemeResource SystemAccentColor}" CornerRadius="8" Padding="10,4" VerticalAlignment="Center" Margin="8,4,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock x:Name="TxtIptvCount" Text="0" FontSize="14" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="IPTV" FontSize="11" Opacity="0.8" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Border>


                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Actions (Filter Toggle) -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <Button x:Name="GenreFilterButton" Click="GenreFilterButton_Click" 
                        Style="{StaticResource GlassButtonStyle}" 
                        Padding="16,8" CornerRadius="20" Background="#10FFFFFF">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE71C;" FontSize="16"/>
                        <TextBlock Text="Filtrele" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer x:Name="MainScrollViewer" Grid.Row="1" Padding="48,0,48,48" ViewChanged="MainScrollViewer_ViewChanged">
            <StackPanel x:Name="ResultsStack" Spacing="40">
                
                <!-- Initial Shimmer State -->
                <StackPanel x:Name="GlobalShimmer" Spacing="16" Visibility="Collapsed">
                    <GridView ItemsSource="{x:Bind ShimmerItems}" 
                              ItemTemplate="{StaticResource ShimmerResultTemplate}"
                              ItemsPanel="{StaticResource SearchGridPanelTemplate}"
                              SelectionMode="None" IsItemClickEnabled="False"/>
                </StackPanel>
                
                <!-- Section 1: Stremio Results -->
                <StackPanel x:Name="StremioSection" Spacing="12" Visibility="Collapsed">
                    <TextBlock x:Name="StremioSectionTitle" Text="Stremio Sonuçları" FontSize="20" FontWeight="Bold" Opacity="0.9"/>
                    
                    <GridView x:Name="StremioGrid" 
                              SelectionMode="None" IsItemClickEnabled="True" 
                              ItemClick="ResultsGrid_ItemClick"
                              ItemTemplate="{StaticResource SearchResultTemplate}"
                              ItemsPanel="{StaticResource SearchGridPanelTemplate}"
                              Padding="0,32,0,32">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0,0,20,32"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                            </Style>
                        </GridView.ItemContainerStyle>
                    </GridView>
                </StackPanel>

                <!-- Section 2: IPTV Results -->
                <StackPanel x:Name="IptvSection" Spacing="12" Visibility="Collapsed">
                    <TextBlock Text="IPTV Sonuçları" FontSize="20" FontWeight="Bold" Opacity="0.9"/>
                    
                    <GridView x:Name="IptvGrid" 
                              SelectionMode="None" IsItemClickEnabled="True" 
                              ItemClick="ResultsGrid_ItemClick"
                              ItemTemplate="{StaticResource SearchResultTemplate}"
                              ItemsPanel="{StaticResource SearchGridPanelTemplate}"
                              Padding="0,32,0,32">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0,0,20,32"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <Setter Property="MinWidth" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                            </Style>
                        </GridView.ItemContainerStyle>
                    </GridView>
                </StackPanel>

                <!-- Load More Indicator -->
                <ProgressBar x:Name="LoadMoreProgress" IsIndeterminate="True" Visibility="Collapsed" Height="4" HorizontalAlignment="Stretch" Margin="0,20"/>

            </StackPanel>
        </ScrollViewer>
        
        <!-- Empty State -->
        <StackPanel x:Name="EmptyPanel" Grid.Row="1" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="48" Margin="0,0,0,100">
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <FontIcon Glyph="&#xE721;" FontSize="64" Foreground="#20FFFFFF"/>
                <TextBlock Text="Aradığınızı bulamadık maalesef..." FontSize="24" FontWeight="Bold" Foreground="White" Opacity="0.9" HorizontalAlignment="Center"/>
                <TextBlock Text="Farklı anahtar kelimeler deneyebilir veya aşağıdaki popüler kategorilere göz atabilirsiniz." 
                           FontSize="14" Foreground="#80FFFFFF" TextAlignment="Center" MaxWidth="400"/>
            </StackPanel>

            <!-- Discovery Suggestions on Empty Page -->
            <StackPanel Spacing="24">
                <TextBlock Text="Popüler Kategoriler" FontSize="18" FontWeight="SemiBold" Foreground="White" Opacity="0.7" HorizontalAlignment="Center"/>
                <ItemsControl x:Name="SuggestionGrid">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VariableSizedWrapGrid Orientation="Horizontal" HorizontalAlignment="Center" ItemWidth="160" ItemHeight="60"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="stremio:GenreSelectionArgs">
                            <Button Click="Suggestion_Click" Margin="4" Padding="16,8" 
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                    Background="#15FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="30">
                                <TextBlock Text="{x:Bind DisplayName}" FontSize="13" FontWeight="Medium"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>

        <!-- GENRE OVERLAY -->
        <controls:GenreSelectionOverlay x:Name="GenreOverlay" Grid.RowSpan="2" Canvas.ZIndex="998" Visibility="Collapsed"/>

        <!-- EXPANDED CARD OVERLAY -->
        <Rectangle x:Name="CinemaScrim" Grid.RowSpan="2" Visibility="Collapsed" Fill="#CC000000" Opacity="0" Canvas.ZIndex="1000"/>
        <Canvas x:Name="OverlayCanvas" Grid.RowSpan="2" Background="{x:Null}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="Collapsed" IsHitTestVisible="False" Canvas.ZIndex="1001" PointerWheelChanged="OverlayCanvas_PointerWheelChanged">
            <controls:ExpandedCard x:Name="ActiveExpandedCard" Visibility="Collapsed" IsHitTestVisible="True"/>
        </Canvas>
    </Grid>
    </Grid>
</Page>
