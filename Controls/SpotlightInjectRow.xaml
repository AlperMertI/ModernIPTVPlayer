<UserControl
    x:Class="ModernIPTVPlayer.Controls.SpotlightInjectRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernIPTVPlayer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ModernIPTVPlayer.Models"
    xmlns:stremio="using:ModernIPTVPlayer.Models.Stremio"
    mc:Ignorable="d"
    d:DesignHeight="400"
    d:DesignWidth="1200"
    Loaded="UserControl_Loaded"
    Unloaded="UserControl_Unloaded"
    SizeChanged="UserControl_SizeChanged">

    <UserControl.Resources>
        <Style x:Key="SpotlightArrowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="0"/>
            <Setter Property="FocusVisualSecondaryThickness" Value="0"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)" To="#44FFFFFF" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="Opacity" To="0.7" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>


    <Grid Padding="0" x:Name="RootContainer" IsTabStop="False" Background="Transparent">
        <Border Background="#111" 
                Height="400" 
                x:Name="ContainerBorder" 
                VerticalAlignment="Top"
                Margin="48,0">
            <Border.RenderTransform>
                <CompositeTransform x:Name="ContainerTransform" CenterX="600" />
            </Border.RenderTransform>
            <!-- Content Grid for Spotlight items -->
            <Grid x:Name="ContainerGrid" Background="#111">
                <!-- Image Fallback -->
                <Image x:Name="FallbackImage" Stretch="UniformToFill" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <!-- WebView for Video (Solid background prevents backdrop bleed at clipped edges) -->
                <Grid x:Name="VideoContainer" Background="Black" Opacity="0" IsHitTestVisible="False" />

                <!-- Navigation Arrows -->
                <Button x:Name="PrevButton" Click="PrevButton_Click" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" Style="{StaticResource SpotlightArrowButtonStyle}" Canvas.ZIndex="10">
                    <FontIcon Glyph="&#xE760;" FontSize="16"/>
                </Button>
                <Button x:Name="NextButton" Click="NextButton_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" Style="{StaticResource SpotlightArrowButtonStyle}" Canvas.ZIndex="10">
                    <FontIcon Glyph="&#xE761;" FontSize="16"/>
                </Button>

                <!-- Spotlight Info Overlay -->
                <StackPanel x:Name="InfoPanel" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="72,0,0,48" MaxWidth="600">
                    <StackPanel.RenderTransform>
                        <CompositeTransform x:Name="InfoTransform" />
                    </StackPanel.RenderTransform>
                    <!-- Spotlight Badge -->
                    <HyperlinkButton Click="HeaderLink_Click" Padding="0" Margin="0,0,0,12" Background="Transparent" BorderThickness="0" IsTabStop="False" FocusVisualPrimaryThickness="0" FocusVisualSecondaryThickness="0">
                        <Border Background="{ThemeResource SystemAccentColor}" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                            <TextBlock Text="SPOTLIGHT" Foreground="White" FontSize="12" FontWeight="Bold" CharacterSpacing="100"/>
                        </Border>
                        <ToolTipService.ToolTip>
                            <ToolTip Content="Tümünü Gör"/>
                        </ToolTipService.ToolTip>
                    </HyperlinkButton>
                    
                    <Image x:Name="LogoImage" Height="60" MaxWidth="400" HorizontalAlignment="Left" Visibility="Collapsed" Stretch="Uniform" Margin="0,0,0,12"/>
                    <TextBlock x:Name="TitleBlock" 
                                Text="" 
                                Foreground="White" 
                                FontSize="36" 
                                FontWeight="Bold" 
                                TextWrapping="Wrap" 
                                Margin="0,0,0,8"/>
                                
                    <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                        <TextBlock x:Name="YearBlock" Text="" Foreground="#B3FFFFFF" FontSize="14"/>
                        <TextBlock Text="•" Foreground="#4DFFFFFF" FontSize="14"/>
                        <TextBlock x:Name="RatingBlock" Text="" Foreground="{ThemeResource SystemAccentColor}" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                                    <TextBlock x:Name="DescriptionBlock"
                                Text=""
                                Foreground="#B3FFFFFF"
                                FontSize="14"
                                TextWrapping="Wrap"
                                MaxLines="3"
                                TextTrimming="CharacterEllipsis"
                                Margin="0,0,0,24"/>
                                
                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Button x:Name="PlayButton" Click="PlayButton_Click" Background="{ThemeResource SystemAccentColor}" Padding="24,12" CornerRadius="8" IsTabStop="False" FocusVisualPrimaryThickness="0" FocusVisualSecondaryThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE768;" FontSize="16"/>
                                <TextBlock Text="Şimdi İzle" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="WatchlistButton" Click="WatchlistButton_Click" Background="#33FFFFFF" Padding="16,12" CornerRadius="8" IsTabStop="False" FocusVisualPrimaryThickness="0" FocusVisualSecondaryThickness="0">
                            <FontIcon Glyph="&#xE710;" FontSize="16"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Trailer Controls -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,24" Spacing="8">
                    <Button x:Name="MuteButton"
                            Click="MuteButton_Click"
                            Width="44" Height="44"
                            CornerRadius="22"
                            Background="#66000000"
                            BorderThickness="1"
                            BorderBrush="#44FFFFFF"
                            Padding="0"
                            Visibility="Collapsed"
                            IsTabStop="False" FocusVisualPrimaryThickness="0" FocusVisualSecondaryThickness="0">
                        <FontIcon x:Name="MuteIcon" Glyph="&#xE74F;" FontSize="16" Foreground="White"/>
                    </Button>

                    <Button x:Name="ExpandButton" 
                            Click="ExpandButton_Click"
                            Width="44" Height="44"
                            CornerRadius="22"
                            Background="#66000000"
                            BorderThickness="1"
                            BorderBrush="#44FFFFFF"
                            Padding="0"
                            Visibility="Collapsed"
                            IsTabStop="False" FocusVisualPrimaryThickness="0" FocusVisualSecondaryThickness="0">
                        <FontIcon Glyph="&#xE740;" FontSize="16" Foreground="White"/>
                    </Button>
                </StackPanel>

                <!-- Preloader for Logos (Hidden) -->
                <Image x:Name="LogoPreloader" Opacity="0" IsHitTestVisible="False" Width="1" Height="1"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
