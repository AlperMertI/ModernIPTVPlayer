<UserControl
    x:Class="ModernIPTVPlayer.Controls.LandscapeCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernIPTVPlayer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    

    <Grid x:Name="RootGrid" 
          Background="Transparent" 
          RenderTransformOrigin="0.5,0.5"
          Loaded="Card_Loaded"
          Unloaded="Card_Unloaded"
          Padding="12"> <!-- Using padding to provide internal "bleed" room for hover zoom on wide cards -->

        <Grid.Resources>
            <Storyboard x:Name="HoverInStoryboard">
                <DoubleAnimation Storyboard.TargetName="ScaleTrans" Storyboard.TargetProperty="ScaleX" To="1.05" Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="ScaleTrans" Storyboard.TargetProperty="ScaleY" To="1.05" Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            <Storyboard x:Name="HoverOutStoryboard">
                <DoubleAnimation Storyboard.TargetName="ScaleTrans" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="ScaleTrans" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>

        <!-- Viewport safety -->

        <!-- Main Content -->
        <Border x:Name="MainBorder" CornerRadius="12" Background="#FF1a1a1a" RenderTransformOrigin="0.5,0.5"
                PointerEntered="OnPointerEntered"
                PointerExited="OnPointerExited"
                PointerMoved="OnPointerMoved"
                Tapped="OnTapped">
            <Border.RenderTransform>
                <ScaleTransform x:Name="ScaleTrans" ScaleX="1.0" ScaleY="1.0"/>
            </Border.RenderTransform>
            <Grid>
                <Grid x:Name="ImageContainer" Background="Transparent">
                    <Image x:Name="PosterImage" Stretch="UniformToFill" ImageOpened="Image_ImageOpened" ImageFailed="Image_ImageFailed"/>
                </Grid>

                <!-- Title & Meta Overlay -->
                <Grid VerticalAlignment="Bottom" Padding="16,0,16,16" IsHitTestVisible="False">
                    <Grid.Background>
                        <SolidColorBrush Color="Transparent"/>
                    </Grid.Background>
                    <StackPanel VerticalAlignment="Bottom">
                        <TextBlock Text="{x:Bind Title, Mode=OneWay}" 
                                   Foreground="White" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"/>

                        <TextBlock Text="{x:Bind Subtext, Mode=OneWay}" 
                                   Foreground="White" 
                                   FontSize="13" 
                                   Opacity="0.8"
                                   FontWeight="SemiBold"
                                   Visibility="{x:Bind GetVisibility(Subtext), Mode=OneWay}"
                                   Margin="0,2,0,0"/>
                                   
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0"
                                    Visibility="{x:Bind GetVisibility(ShowMeta), Mode=OneWay}">
                             <TextBlock Text="{x:Bind Year, Mode=OneWay}" Foreground="#B3FFFFFF" FontSize="12"/>
                             <TextBlock Text="•" Foreground="#4DFFFFFF" FontSize="12" Visibility="{x:Bind GetVisibility(RatingText), Mode=OneWay}"/>
                             <TextBlock Text="{x:Bind RatingText, Mode=OneWay}" Foreground="{ThemeResource SystemAccentColor}" FontSize="12" FontWeight="SemiBold" Visibility="{x:Bind GetVisibility(RatingText), Mode=OneWay}"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
                
                <!-- Center Play Icon (Hover Effect) -->
                <Viewbox Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid x:Name="PlayButtonContainer" Opacity="0.8">
                       <Ellipse Fill="#80000000" Width="48" Height="48"/>
                       <FontIcon Glyph="&#xE768;" FontSize="20" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Grid>
                </Viewbox>

                <!-- Progress Bar -->
                <ProgressBar VerticalAlignment="Bottom" Height="6" 
                             Value="{x:Bind ProgressValue, Mode=OneWay}" 
                             Maximum="100"
                             Foreground="{ThemeResource SystemAccentColor}"
                             Background="#60000000"
                             BorderThickness="0"
                             Visibility="{x:Bind ShowProgress, Mode=OneWay}"/>
                
                <!-- Status Badge (Top Right) -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Margin="12" CornerRadius="6" 
                        Padding="8,4"
                        Visibility="{x:Bind ShowBadge, Mode=OneWay}">
                    <Border.Background>
                        <AcrylicBrush TintColor="Black" TintOpacity="0.7" FallbackColor="#E6000000"/>
                    </Border.Background>
                    <TextBlock Text="{x:Bind BadgeText, Mode=OneWay}" 
                               Foreground="White" FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
