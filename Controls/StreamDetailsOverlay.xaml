<UserControl
    x:Class="ModernIPTVPlayer.Controls.StreamDetailsOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <UserControl.Resources>
        <!-- Standard Label Style -->
        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#66FFFFFF"/>
            <Setter Property="CharacterSpacing" Value="60"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Unified Stat Item Template (Implicitly used by naming convention) -->
        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Skeleton Rectangle Style -->
        <Style x:Key="SkeletonStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="#15FFFFFF"/>
            <Setter Property="RadiusX" Value="6"/>
            <Setter Property="RadiusY" Value="6"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Background="#AA000000" Visibility="Collapsed" Tapped="RootGrid_Tapped">
        <Border x:Name="MainCard"
                Tapped="MainCard_Tapped"
                Width="540" Height="680"
                CornerRadius="28"
                Background="{ThemeResource SystemControlAcrylicElementBrush}"
                BorderBrush="#1AFFFFFF"
                BorderThickness="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            
            <Border.Shadow><ThemeShadow /></Border.Shadow>

            <Grid RowDefinitions="Auto,*,Auto">
                
                <!-- Header -->
                <Grid Grid.Row="0" Padding="32,32,32,12">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Border Width="48" Height="48" CornerRadius="16" Background="{ThemeResource AccentFillColorDefaultBrush}">
                            <FontIcon Glyph="&#xE946;" FontSize="22" Foreground="White"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Teknik Metadata" FontSize="24" FontWeight="Black" CharacterSpacing="-20"/>
                            <TextBlock Text="Yüksek Hassasiyetli Yayın Analizi" FontSize="11" Opacity="0.4"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Click="CloseButton_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Style="{StaticResource SubtleButtonStyle}" Padding="8" CornerRadius="12">
                        <SymbolIcon Symbol="Cancel"/>
                    </Button>
                </Grid>

                <!-- Content Area -->
                <Pivot x:Name="MainPivot" Grid.Row="1" Margin="20,0,20,0" SelectedIndex="1">
                    
                    <!-- TAB 0: GENEL -->
                    <PivotItem Header="Genel">
                        <ScrollViewer Padding="12">
                            <StackPanel Spacing="24">
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="20" RowDefinitions="Auto,Auto,Auto" RowSpacing="20">
                                    <!-- Unified Stat Pairs -->
                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="KONTEYNER" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_Container" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_Container" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <TextBlock Text="PROTOKOL" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_Protocol" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_Protocol" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock Text="MIME TYPE" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_Mime" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_Mime" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                        <TextBlock Text="SUNUCU" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_Server" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_Server" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                                        <TextBlock Text="KODLAYICI (ENCODER)" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_Encoder" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_Encoder" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                                <Border Background="#08FFFFFF" CornerRadius="16" Padding="16" BorderBrush="#0DFFFFFF" BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Altyazı Kanalları" FontSize="11" FontWeight="Bold" Opacity="0.6"/>
                                        <TextBlock x:Name="V_Subtitles" Text="Bekleniyor..." FontSize="13" TextWrapping="Wrap" Opacity="0.9"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>

                    <!-- TAB 1: VİDEO & SES -->
                    <PivotItem Header="Video &amp; Ses">
                        <ScrollViewer Padding="12">
                            <StackPanel Spacing="24">
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="20" RowDefinitions="Auto,Auto,Auto" RowSpacing="20">
                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="ÇÖZÜNÜRLÜK" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_Res" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_Res" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1">
                                        <TextBlock Text="VİDEO CODEC" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_VideoCodec" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_VideoCodec" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0">
                                        <TextBlock Text="KARE HIZI (FPS)" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_Fps" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_Fps" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1">
                                        <TextBlock Text="BITRATE" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_Bitrate" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_Bitrate" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="0">
                                        <TextBlock Text="RENK UZAYI &amp; HDR" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_ColorSpace" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_ColorSpace" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1">
                                        <TextBlock Text="TARAMA TİPİ" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_Scan" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_Scan" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="CHROMA SUBSAMPLING" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_Chroma" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_Chroma" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="COLOR RANGE" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_Range" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_Range" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                                <Rectangle Height="1" Fill="#11FFFFFF"/>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="SES CODEC &amp; KANAL" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_Audio" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_Audio" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="DİL SEÇENEKLERİ" Style="{StaticResource StatLabelStyle}"/>
                                        <Grid>
                                            <Rectangle x:Name="S_Langs" Style="{StaticResource SkeletonStyle}"/>
                                            <TextBlock x:Name="V_Langs" Style="{StaticResource StatValueStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>

                    <!-- TAB 2: PERFORMANS -->
                    <PivotItem Header="Performans">
                        <ScrollViewer Padding="12">
                            <StackPanel Spacing="24">
                                <StackPanel>
                                    <TextBlock Text="TAMPONLAMA DURUMU (BUFFER)" Style="{StaticResource StatLabelStyle}"/>
                                    <Grid>
                                        <ProgressBar x:Name="BufferProgress" Maximum="10" Value="0" Height="4" Margin="0,8,0,0"/>
                                        <TextBlock x:Name="V_Buffer" Text="0.00 sn / 0 MB" FontSize="12" HorizontalAlignment="Right" Margin="0,-18,0,0" Opacity="0.7"/>
                                    </Grid>
                                </StackPanel>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="A/V SENKRON" Style="{StaticResource StatLabelStyle}"/>
                                        <TextBlock x:Name="V_AvSync" Text="0.00 ms" Style="{StaticResource StatValueStyle}" Visibility="Visible" Opacity="1"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="ŞİFRELEME / DRM" Style="{StaticResource StatLabelStyle}"/>
                                        <TextBlock x:Name="V_Drm" Text="None" Style="{StaticResource StatValueStyle}" Visibility="Visible" Opacity="1"/>
                                    </StackPanel>
                                </Grid>
                                <Border Background="#11FFFFFF" CornerRadius="16" Padding="16">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Performans Notu" FontSize="12" FontWeight="Bold" Foreground="{ThemeResource AccentFillColorDefaultBrush}"/>
                                        <TextBlock Text="Demuxer ve Decoder istatistikleri anlık olarak MPV Core üzerinden çekilmektedir." FontSize="11" Opacity="0.5" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </PivotItem>
                </Pivot>

                <Grid Grid.Row="2" Padding="32,20,32,32">
                    <TextBlock Text="MODERN IPTV TECHNICAL ANALYSIS ENGINE v3.5 // COMPOSITION SHIMMER ACTIVE" FontSize="10" Opacity="0.2" HorizontalAlignment="Center" FontWeight="Bold" CharacterSpacing="100"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
