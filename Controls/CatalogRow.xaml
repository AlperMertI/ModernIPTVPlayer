<UserControl
    x:Class="ModernIPTVPlayer.Controls.CatalogRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernIPTVPlayer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ModernIPTVPlayer.Models.Stremio"
    xmlns:converters="using:ModernIPTVPlayer.Converters"
    mc:Ignorable="d"
    x:Name="RootControl">

    <UserControl.Resources>
        <converters:BoolToVisibleConverter x:Key="BoolToVisibleConverter"/>
        <converters:BoolToCollapsedConverter x:Key="BoolToCollapsedConverter"/>

        <DataTemplate x:Key="ShimmerStandardTemplate">
            <local:ShimmerCard Width="172" Height="252" Margin="0,0,12,0"/>
        </DataTemplate>
        <DataTemplate x:Key="ShimmerLandscapeTemplate">
            <local:ShimmerCard Width="296" Height="176" Margin="0,0,12,0"/>
        </DataTemplate>
        
        <local:RowStyleToTemplateConverter x:Key="ShimmerTemplateConverter" 
                                           StandardTemplate="{StaticResource ShimmerStandardTemplate}" 
                                           LandscapeTemplate="{StaticResource ShimmerLandscapeTemplate}" />
    </UserControl.Resources>

    <Grid x:Name="RootPanel" Margin="0" Opacity="0"
                PointerEntered="RootPanel_PointerEntered" 
                PointerExited="RootPanel_PointerExited">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="LoadingStates">
                <VisualState x:Name="Loading">
                    <VisualState.Setters>
                        <Setter Target="ShimmerPanel.Visibility" Value="Visible"/>
                        <Setter Target="ItemsScrollViewer.Visibility" Value="Collapsed"/>
                        <Setter Target="RootPanel.Opacity" Value="0.6"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="ContentReady">
                    <VisualState.Setters>
                        <Setter Target="ShimmerPanel.Visibility" Value="Collapsed"/>
                        <Setter Target="ItemsScrollViewer.Visibility" Value="Visible"/>
                        <Setter Target="RootPanel.Opacity" Value="1"/>
                    </VisualState.Setters>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="EntranceTranslation" 
                                          Storyboard.TargetProperty="Y" 
                                          To="0" Duration="0:0:0.6">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="RootPanel" 
                                          Storyboard.TargetProperty="Opacity" 
                                          To="1" Duration="0:0:0.4"/>
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="Empty">
                    <VisualState.Setters>
                        <Setter Target="RootPanel.Visibility" Value="Collapsed"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>

                <VisualStateGroup x:Name="HoverStates">
                    <VisualState x:Name="Normal">
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ScrollLeftButton" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                            <DoubleAnimation Storyboard.TargetName="ScrollRightButton" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ScrollLeftButton" Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="Collapsed"/>
                            </ObjectAnimationUsingKeyFrames>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ScrollRightButton" Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0:0:0.2" Value="Collapsed"/>
                            </ObjectAnimationUsingKeyFrames>
                        </Storyboard>
                    </VisualState>
                    <VisualState x:Name="PointerOver">
                        <Storyboard>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ScrollLeftButton" Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                            </ObjectAnimationUsingKeyFrames>
                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ScrollRightButton" Storyboard.TargetProperty="Visibility">
                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                            </ObjectAnimationUsingKeyFrames>
                            <DoubleAnimation Storyboard.TargetName="ScrollLeftButton" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                            <DoubleAnimation Storyboard.TargetName="ScrollRightButton" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                        </Storyboard>
                    </VisualState>
                </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RenderTransform>
            <TranslateTransform x:Name="EntranceTranslation" Y="40"/>
        </Grid.RenderTransform>
        
        <HyperlinkButton x:Name="HeaderLink" Grid.Row="0"
                         Click="HeaderLink_Click" 
                         Padding="0" Margin="48,0,0,0" 
                         Background="Transparent" BorderThickness="0"
                         IsEnabled="{x:Bind IsHeaderInteractive, Mode=OneWay}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Name="RowTitle" Text="{x:Bind CatalogName, Mode=OneWay}" FontSize="22" FontWeight="Bold" Foreground="White" CharacterSpacing="20"/>
                <FontIcon Glyph="&#xE76C;" FontSize="14" VerticalAlignment="Center" Margin="0,4,0,0"
                          Visibility="{x:Bind IsHeaderInteractive, Converter={StaticResource BoolToVisibleConverter}, Mode=OneWay}"/>
            </StackPanel>
            <ToolTipService.ToolTip>
                <ToolTip Content="Tümünü Gör" Visibility="{x:Bind IsHeaderInteractive, Converter={StaticResource BoolToVisibleConverter}, Mode=OneWay}"/>
            </ToolTipService.ToolTip>
        </HyperlinkButton>
        

        <Grid x:Name="ListContainer" Grid.Row="1" Margin="0,12,0,0">
            <!-- Shimmer State -->
            <ItemsRepeater x:Name="ShimmerPanel" 
                           Visibility="Collapsed" 
                           Margin="48,0,48,0"
                           ItemTemplate="{x:Bind RowStyle, Converter={StaticResource ShimmerTemplateConverter}, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Horizontal" Spacing="12"/>
                </ItemsRepeater.Layout>
            </ItemsRepeater>

            <ScrollViewer x:Name="ItemsScrollViewer" 
                          HorizontalScrollMode="Disabled"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Hidden"
                          IsHorizontalScrollChainingEnabled="False"
                          ManipulationMode="TranslateX"
                          Loaded="ItemsScrollViewer_Loaded">
                <ItemsRepeater x:Name="Repeater" 
                               ItemsSource="{x:Bind ItemsSource, Mode=OneWay}"
                               ItemTemplate="{x:Bind ItemTemplate, Mode=OneWay}"
                               HorizontalCacheLength="2.0"
                               ElementPrepared="Repeater_ElementPrepared"
                               ElementClearing="Repeater_ElementClearing"
                               ManipulationMode="TranslateX"
                               ManipulationStarted="Repeater_ManipulationStarted"
                               ManipulationDelta="Repeater_ManipulationDelta"
                               ManipulationCompleted="Repeater_ManipulationCompleted"
                               Margin="48,0,48,0">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="12"/>
                    </ItemsRepeater.Layout>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- Navigation Arrows (Hero Style) -->
            <Button x:Name="ScrollRightButton" 
                    Click="ScrollRight_Click"
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Center" 
                    Margin="0,0,24,0"
                    Style="{StaticResource VortexButtonStyle}" 
                    Width="48" Height="48" 
                    Canvas.ZIndex="1000"
                    IsHitTestVisible="True"
                    PointerEntered="Button_PointerEntered"
                    Visibility="Collapsed"
                    Opacity="0">
                <FontIcon Glyph="&#xE761;" FontSize="18"/>
            </Button>
            
            <Button x:Name="ScrollLeftButton" 
                    Click="ScrollLeft_Click"
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Center" 
                    Margin="24,0,0,0"
                    Style="{StaticResource VortexButtonStyle}" 
                    Width="48" Height="48" 
                    Canvas.ZIndex="1000"
                    IsHitTestVisible="True"
                    PointerEntered="Button_PointerEntered"
                    Visibility="Collapsed"
                    Opacity="0">
                <FontIcon Glyph="&#xE760;" FontSize="18"/>
            </Button>
        </Grid>
    </Grid>
</UserControl>
