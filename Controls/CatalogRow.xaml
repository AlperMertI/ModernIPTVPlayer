<UserControl
    x:Class="ModernIPTVPlayer.Controls.CatalogRow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernIPTVPlayer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ModernIPTVPlayer.Models.Stremio"
    xmlns:converters="using:ModernIPTVPlayer.Converters"
    mc:Ignorable="d"
    x:Name="RootControl">

    <UserControl.Resources>
        <converters:BoolToVisibleConverter x:Key="BoolToVisibleConverter"/>
        <converters:BoolToCollapsedConverter x:Key="BoolToCollapsedConverter"/>
    </UserControl.Resources>

    <Grid x:Name="RootPanel" Margin="0" Opacity="0"
                PointerEntered="RootPanel_PointerEntered" 
                PointerExited="RootPanel_PointerExited">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="HoverStates">
                <VisualState x:Name="Normal"/>
                <VisualState x:Name="PointerOver">
                    <VisualState.Setters>
                        <Setter Target="ScrollRightButton.Visibility" Value="Visible"/>
                        <Setter Target="ScrollLeftButton.Visibility" Value="Visible"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
            
            <VisualStateGroup x:Name="RowStyleStates">
                <VisualState x:Name="Standard">
                    <VisualState.Setters>
                        <Setter Target="S1.Width" Value="152"/>
                        <Setter Target="S1.Height" Value="232"/>
                        <Setter Target="S1.Margin" Value="10,10,14,10"/>
                        <Setter Target="S2.Width" Value="152"/>
                        <Setter Target="S2.Height" Value="232"/>
                        <Setter Target="S2.Margin" Value="10,10,14,10"/>
                        <Setter Target="S3.Width" Value="152"/>
                        <Setter Target="S3.Height" Value="232"/>
                        <Setter Target="S3.Margin" Value="10,10,14,10"/>
                        <Setter Target="S4.Width" Value="152"/>
                        <Setter Target="S4.Height" Value="232"/>
                        <Setter Target="S4.Margin" Value="10,10,14,10"/>
                        <Setter Target="S5.Width" Value="152"/>
                        <Setter Target="S5.Height" Value="232"/>
                        <Setter Target="S5.Margin" Value="10,10,14,10"/>
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Landscape">
                    <VisualState.Setters>
                        <Setter Target="S1.Width" Value="272"/>
                        <Setter Target="S1.Height" Value="152"/>
                        <Setter Target="S1.Margin" Value="12,12,16,12"/>
                        <Setter Target="S2.Width" Value="272"/>
                        <Setter Target="S2.Height" Value="152"/>
                        <Setter Target="S2.Margin" Value="12,12,16,12"/>
                        <Setter Target="S3.Width" Value="272"/>
                        <Setter Target="S3.Height" Value="152"/>
                        <Setter Target="S3.Margin" Value="12,12,16,12"/>
                        <Setter Target="S4.Width" Value="272"/>
                        <Setter Target="S4.Height" Value="152"/>
                        <Setter Target="S4.Margin" Value="12,12,16,12"/>
                        <Setter Target="S5.Width" Value="272"/>
                        <Setter Target="S5.Height" Value="152"/>
                        <Setter Target="S5.Margin" Value="12,12,16,12"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RenderTransform>
            <TranslateTransform x:Name="EntranceTranslation" Y="40"/>
        </Grid.RenderTransform>
        
        <HyperlinkButton x:Name="HeaderLink" Grid.Row="0"
                         Click="HeaderLink_Click" 
                         Padding="0" Margin="48,0,0,0" 
                         Background="Transparent" BorderThickness="0"
                         IsEnabled="{x:Bind IsHeaderInteractive, Mode=OneWay}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Name="RowTitle" Text="{x:Bind CatalogName, Mode=OneWay}" FontSize="22" FontWeight="Bold" Foreground="White" CharacterSpacing="20"/>
                <FontIcon Glyph="&#xE76C;" FontSize="14" VerticalAlignment="Center" Margin="0,4,0,0"
                          Visibility="{x:Bind IsHeaderInteractive, Converter={StaticResource BoolToVisibleConverter}, Mode=OneWay}"/>
            </StackPanel>
            <ToolTipService.ToolTip>
                <ToolTip Content="Tümünü Gör" Visibility="{x:Bind IsHeaderInteractive, Converter={StaticResource BoolToVisibleConverter}, Mode=OneWay}"/>
            </ToolTipService.ToolTip>
        </HyperlinkButton>
        

        <Grid x:Name="ListContainer" Grid.Row="1" Margin="0,12,0,0">
            <!-- Shimmer State -->
            <StackPanel x:Name="ShimmerPanel" Orientation="Horizontal" Visibility="Collapsed" Margin="-10,0,0,0">
                 <local:ShimmerCard x:Name="S1" Width="172" Height="252" Margin="0,0,4,0"/>
                 <local:ShimmerCard x:Name="S2" Width="172" Height="252" Margin="0,0,4,0"/>
                 <local:ShimmerCard x:Name="S3" Width="172" Height="252" Margin="0,0,4,0"/>
                 <local:ShimmerCard x:Name="S4" Width="172" Height="252" Margin="0,0,4,0"/>
                 <local:ShimmerCard x:Name="S5" Width="172" Height="252" Margin="0,0,4,0"/>
            </StackPanel>

            <ScrollViewer x:Name="ItemsScrollViewer" 
                          HorizontalScrollMode="Disabled"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollMode="Disabled"
                          VerticalScrollBarVisibility="Disabled"
                          IsVerticalRailEnabled="False"
                          IsHorizontalRailEnabled="False"
                          IsVerticalScrollChainingEnabled="True"
                          IsHorizontalScrollChainingEnabled="False"
                          AllowFocusOnInteraction="False"
                          IsTabStop="False"
                          Visibility="{x:Bind IsLoading, Mode=OneWay, Converter={StaticResource BoolToCollapsedConverter}}"
                          Loaded="ItemsScrollViewer_Loaded">
                <ItemsRepeater x:Name="Repeater" 
                               ItemsSource="{x:Bind ItemsSource, Mode=OneWay}"
                               ItemTemplate="{x:Bind ItemTemplate, Mode=OneWay}"
                               ElementPrepared="Repeater_ElementPrepared"
                               ElementClearing="Repeater_ElementClearing"
                               ManipulationMode="TranslateX, System"
                               ManipulationDelta="Repeater_ManipulationDelta"
                               Margin="48,0,48,0">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Horizontal" Spacing="12"/>
                    </ItemsRepeater.Layout>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- Navigation Arrows -->
            <Button x:Name="ScrollRightButton" 
                    Click="ScrollRight_Click"
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Center" 
                    Margin="0,0,24,0"
                    Style="{StaticResource VortexButtonStyle}" 
                    Width="56" Height="56" 
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Canvas.ZIndex="1000"
                    IsHitTestVisible="True"
                    Background="#11FFFFFF"
                    PointerEntered="Button_PointerEntered"
                    Visibility="Collapsed">
                <FontIcon Glyph="&#xE761;" FontSize="20" FontWeight="Bold"/>
            </Button>
            
            <Button x:Name="ScrollLeftButton" 
                    Click="ScrollLeft_Click"
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Center" 
                    Margin="24,0,0,0"
                    Style="{StaticResource VortexButtonStyle}" 
                    Width="56" Height="56" 
                    Padding="0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Canvas.ZIndex="1000"
                    IsHitTestVisible="True"
                    Background="#11FFFFFF"
                    PointerEntered="Button_PointerEntered"
                    Visibility="Collapsed">
                <FontIcon Glyph="&#xE760;" FontSize="20" FontWeight="Bold"/>
            </Button>
        </Grid>
    </Grid>
</UserControl>
