<UserControl
    x:Class="ModernIPTVPlayer.Controls.ShimmerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="20"
    d:DesignWidth="200">

    <Grid x:Name="ShimmerMask" CornerRadius="{x:Bind CornerRadius, Mode=OneWay}" Background="{x:Bind BaseBrush, Mode=OneWay}">
        <Rectangle x:Name="ShimmerRect" Width="{x:Bind SweepWidth, Mode=OneWay}" HorizontalAlignment="Left" Opacity="{x:Bind HighlightOpacity, Mode=OneWay}">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#05FFFFFF" Offset="0.22"/>
                    <GradientStop Color="#38FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#08FFFFFF" Offset="0.78"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
            <Rectangle.RenderTransform>
                <TranslateTransform x:Name="ShimmerTransform" X="-360"/>
            </Rectangle.RenderTransform>
        </Rectangle>
    </Grid>
</UserControl>
