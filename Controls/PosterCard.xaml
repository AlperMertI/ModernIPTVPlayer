<UserControl
    x:Class="ModernIPTVPlayer.Controls.PosterCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernIPTVPlayer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:ModernIPTVPlayer.Converters"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibleConverter x:Key="BoolToVis"/>
        <converters:StringToVisibleConverter x:Key="StringToVis"/>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" 
          Background="Transparent" 
          RenderTransformOrigin="0.5,0.5"
          Loaded="PosterCard_Loaded"
          Unloaded="PosterCard_Unloaded"
          Padding="6"> <!-- Optimized padding to reduce empty space while allowing 1.05x zoom bleed -->

        <Grid.Resources>
            <Storyboard x:Name="HoverInStoryboard">
                <DoubleAnimation Storyboard.TargetName="ScaleTrans" Storyboard.TargetProperty="ScaleX" To="1.05" Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="ScaleTrans" Storyboard.TargetProperty="ScaleY" To="1.05" Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            <Storyboard x:Name="HoverOutStoryboard">
                <DoubleAnimation Storyboard.TargetName="ScaleTrans" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="ScaleTrans" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.3">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
            <Storyboard x:Name="FadeInStoryboard">
                <DoubleAnimation Storyboard.TargetName="PosterImage" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.65">
                    <DoubleAnimation.EasingFunction>
                        <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PosterShimmer" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.5">
                    <DoubleAnimation.EasingFunction>
                        <ExponentialEase EasingMode="EaseIn" Exponent="5"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
        </Grid.Resources>

        <!-- Controls scaling on internal elements to avoid cropping -->





        <!-- Main Content -->
        <Border x:Name="MainBorder" CornerRadius="12" Background="#0C0E14" RenderTransformOrigin="0.5,0.5"
                PointerEntered="OnPointerEntered"
                PointerExited="OnPointerExited"
                PointerMoved="OnPointerMoved"
                Tapped="OnTapped">
            <Border.RenderTransform>
                <ScaleTransform x:Name="ScaleTrans" ScaleX="1.0" ScaleY="1.0"/>
            </Border.RenderTransform>
            <Border.Projection>
                <PlaneProjection x:Name="TiltProjection"/>
            </Border.Projection>
            <Grid>
                <local:ShimmerCard x:Name="PosterShimmer" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                <Image x:Name="PosterImage" Stretch="UniformToFill" Opacity="0" ImageOpened="Image_ImageOpened" ImageFailed="Image_ImageFailed"/>
                
                <!-- IPTV Badge (Premium Glassmorphic) -->
                <Border x:Name="IptvBadge" 
                        Visibility="Collapsed" 
                        Background="#CC000000" 
                        BorderBrush="#30FFFFFF"
                        BorderThickness="0.5"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top" 
                        Margin="0,8,8,0" 
                        Padding="8,3" 
                        CornerRadius="14"
                        Canvas.ZIndex="10">
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <Ellipse Width="4" Height="4" Fill="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>
                        <TextBlock Text="KÜTÜPHANE" FontSize="9" FontWeight="Black" Foreground="White" CharacterSpacing="50" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Center Placeholder for missing posters -->
                <TextBlock x:Name="PlaceholderTitle"
                           Text="{x:Bind Title, Mode=OneWay}"
                           Foreground="#44FFFFFF"
                           FontSize="14"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="12"
                           Opacity="0.8"
                           Visibility="Collapsed"/>

                <Grid x:Name="TitleOverlay"
                      VerticalAlignment="Bottom" 
                      Height="70" 
                      IsHitTestVisible="False"
                      Visibility="Collapsed">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#99000000" Offset="0.5"/>
                            <GradientStop Color="#E6000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <StackPanel VerticalAlignment="Center" Margin="8,0,8,0">
                        <TextBlock Text="{x:Bind Title, Mode=OneWay}" 
                                   Foreground="White" 
                                   FontSize="12" 
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{x:Bind Subtext, Mode=OneWay}" 
                                   Foreground="#CCCCCC" 
                                   FontSize="10" 
                                   HorizontalAlignment="Center"
                                   Visibility="{x:Bind HasSubtext, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Premium Progress Indicator (Modern Glow Style) -->
                <Grid x:Name="ProgressIndicator" 
                      VerticalAlignment="Bottom" 
                      Height="3" 
                      Margin="16,0,16,16" 
                      Background="Transparent"
                      Visibility="{x:Bind ShowProgress, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    
                    <!-- Ultra-subtle track -->
                    <Border Background="#15FFFFFF" CornerRadius="1.5"/>
                    
                    <Border x:Name="ProgressBarFill" 
                            HorizontalAlignment="Stretch" 
                            CornerRadius="1.5"
                            RenderTransformOrigin="0,0.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#E50914" Offset="0.0"/>
                                <GradientStop Color="#FF3D47" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.RenderTransform>
                            <CompositeTransform ScaleX="{x:Bind GetProgressScale(ProgressValue), Mode=OneWay}"/>
                        </Border.RenderTransform>
                    </Border>
                </Grid>
                
                <!-- Status Badge (Top Right) -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Margin="8" CornerRadius="4" 
                        Padding="6,2"
                        Visibility="{x:Bind BadgeText, Mode=OneWay, Converter={StaticResource StringToVis}}">
                    <Border.Background>
                        <AcrylicBrush TintColor="Black" TintOpacity="0.6" FallbackColor="Black"/>
                    </Border.Background>
                    <TextBlock Text="{x:Bind BadgeText, Mode=OneWay}" 
                               Foreground="White" FontSize="10" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>


    </Grid>
</UserControl>
