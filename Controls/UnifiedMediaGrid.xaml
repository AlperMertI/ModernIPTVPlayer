<UserControl
    x:Class="ModernIPTVPlayer.Controls.UnifiedMediaGrid"
    x:Name="RootGridControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernIPTVPlayer.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:ModernIPTVPlayer.Models"
    mc:Ignorable="d"
    d:DesignHeight="600"
    d:DesignWidth="800">

    <UserControl.Resources>
        <Style x:Key="MediaCardStyle" TargetType="GridViewItem">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="CanDrag" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewItem">
                        <Grid Background="Transparent" CornerRadius="12">
                            <ContentPresenter x:Name="ContentPresenter"
                                Content="{TemplateBinding Content}"
                                ContentTransitions="{TemplateBinding ContentTransitions}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main Media Grid -->
        <GridView x:Name="MediaGridView" x:FieldModifier="public"
                  SelectionMode="None" 
                  IsItemClickEnabled="False" 
                  ContainerContentChanging="MediaGridView_ContainerContentChanging"
                  Padding="24,0,24,0"
                  Background="Transparent"
                  ItemContainerStyle="{StaticResource MediaCardStyle}">
            
            <GridView.ItemContainerTransitions>
                <TransitionCollection>
                    <!-- <EntranceThemeTransition FromVerticalOffset="100" IsStaggeringEnabled="True"/> -->
                </TransitionCollection>
            </GridView.ItemContainerTransitions>

            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <GridView.ItemTemplate>
                <DataTemplate x:DataType="local:UnifiedMediaItemContext">
                    <Grid Width="212" Height="312" Margin="2">
                        <!-- Phase 0: Immediate Light Skeleton (Automatic) -->
                        <local:ShimmerCard x:Name="Skeleton" Width="212" Height="312" Padding="6"/>
                        
                        <!-- Phase 1: Full Heavy Card -->
                        <local:PosterCard x:Phase="1"
                            DataContext="{x:Bind}"
                            ImageUrl="{x:Bind Data.PosterUrl}" 
                            Title="{x:Bind Data.Title}" 
                            ProgressValue="{x:Bind Data.ProgressValue}"
                            BadgeText="{x:Bind Data.BadgeText}"
                            IsAvailableOnIptv="{x:Bind Data.IsAvailableOnIptv}"
                            ShowProgress="{x:Bind Data.ShowProgress}"
                            ShowIptvBadge="{x:Bind ShowIptvBadge}"
                            ShowBadge="{x:Bind Data.ShowBadge}"
                            IsTitleVisible="{x:Bind ShowTitles}"
                            Width="212" 
                            Height="312"
                            ColorsExtracted="PosterCard_ColorsExtracted"
                            Clicked="PosterCard_Clicked"
                            HoverStarted="Card_HoverStarted"
                            HoverEnded="Card_HoverEnded"/>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
        
        <!-- Skeleton Loading State -->
        <GridView x:Name="SkeletonGrid" 
                  Padding="24,0,24,0"
                  Visibility="Collapsed"
                  IsHitTestVisible="False">
            <GridView.ItemTemplate>
                <DataTemplate>
                    <local:ShimmerCard Width="212" Height="312" Margin="2" Padding="6"/>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
        
        <!-- Flying Panel Overlay -->
        <Canvas x:Name="OverlayCanvas" Visibility="Collapsed">
            <Rectangle x:Name="CinemaScrim" Fill="#FF000000" Opacity="0" Visibility="Collapsed" IsHitTestVisible="False" Canvas.ZIndex="0"/>
            <local:ExpandedCard x:Name="ActiveExpandedCard" x:FieldModifier="public" Visibility="Collapsed" Canvas.ZIndex="1"/>
        </Canvas>

        <!-- Empty State -->
        <StackPanel x:Name="EmptyStatePanel" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" IsHitTestVisible="False">
            <FontIcon Glyph="&#xE773;" FontSize="48" Foreground="#33FFFFFF"/>
            <TextBlock Text="Sonuç Bulunamadı" Foreground="#66FFFFFF" FontSize="16"/>
        </StackPanel>
    </Grid>
</UserControl>
