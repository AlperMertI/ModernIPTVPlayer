<UserControl
    x:Class="ModernIPTVPlayer.Controls.StremioDiscoveryControl"
    x:Name="DiscoveryRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModernIPTVPlayer.Controls"
    xmlns:models="using:ModernIPTVPlayer.Models"
    xmlns:stremioModels="using:ModernIPTVPlayer.Models.Stremio"
    xmlns:converters="using:ModernIPTVPlayer.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="1000"
    d:DesignWidth="1200">
    <UserControl.Resources>
        <DataTemplate x:Key="StandardCardTemplate" x:DataType="stremioModels:StremioMediaStream">
            <local:PosterCard ImageUrl="{x:Bind PosterUrl, Mode=OneWay}" 
                              ShowProgress="{x:Bind ShowProgress, Mode=OneWay}"
                              ProgressValue="{x:Bind ProgressValue, Mode=OneWay}"
                              IsAvailableOnIptv="{x:Bind IsAvailableOnIptv, Mode=OneWay}"
                              ShowIptvBadge="{Binding ShowIptvBadge, ElementName=DiscoveryRoot}"
                              Width="172" Height="252" 
                              HoverStarted="PosterCard_HoverStarted" 
                              HoverEnded="PosterCard_HoverEnded"
                              Tapped="PosterCard_Tapped"
                              ElementSoundMode="Off"/>
        </DataTemplate>
        <DataTemplate x:Key="LandscapeCardTemplate" x:DataType="stremioModels:StremioMediaStream">
            <local:LandscapeCard ImageUrl="{x:Bind LandscapeImageUrl, Mode=OneWay}" 
                                 Title="{x:Bind Title, Mode=OneWay}"
                                 Subtext="{x:Bind DisplaySubtext, Mode=OneWay}"
                                 Year="{x:Bind Year, Mode=OneWay}"
                                 RatingText="{x:Bind Rating, Mode=OneWay}"
                                 ShowProgress="{x:Bind ShowProgress, Mode=OneWay}"
                                 ShowMeta="{x:Bind IsNotContinueWatching, Mode=OneWay}"
                                 ProgressValue="{x:Bind ProgressValue, Mode=OneWay}"
                                 Width="296" Height="176" 
                                 HoverStarted="LandscapeCard_HoverStarted" 
                                 HoverEnded="LandscapeCard_HoverEnded"
                                 Tapped="PosterCard_Tapped"
                                 ElementSoundMode="Off"/>
        </DataTemplate>
        <local:RowStyleToTemplateConverter x:Key="RowStyleToTemplateConverter" 
                                           StandardTemplate="{StaticResource StandardCardTemplate}" 
                                           LandscapeTemplate="{StaticResource LandscapeCardTemplate}" />
                                           
        <!-- Row Level Templates -->
        <DataTemplate x:Key="StandardCatalogRowTemplate" x:DataType="models:CatalogRowViewModel">
            <local:CatalogRow CatalogName="{x:Bind CatalogName, Mode=OneWay}" 
                              ItemsSource="{x:Bind Items, Mode=OneWay}"
                              IsLoading="{x:Bind IsLoading, Mode=OneWay}"
                              IsHeaderInteractive="{x:Bind IsHeaderInteractive, Mode=OneWay}"
                              ItemTemplate="{x:Bind RowStyle, Converter={StaticResource RowStyleToTemplateConverter}, Mode=OneWay}"
                              ItemClicked="CatalogRow_ItemClicked"
                              HoverStarted="CatalogRow_HoverStarted"
                              HoverEnded="CatalogRow_HoverEnded"
                              ScrollStarted="CatalogRow_ScrollStarted"
                              ScrollEnded="CatalogRow_ScrollEnded"
                              HeaderClicked="CatalogRow_HeaderClicked"
                              LoadMoreAction="CatalogRow_LoadMoreAction"/>
        </DataTemplate>

        <DataTemplate x:Key="SpotlightCatalogRowTemplate" x:DataType="models:CatalogRowViewModel">
            <local:SpotlightInjectRow DataContext="{x:Bind Mode=OneWay}" 
                                      ItemClicked="SpotlightInjectRow_ItemClicked"
                                      HeaderClicked="CatalogRow_HeaderClicked" />
        </DataTemplate>

        <local:DiscoveryRowTemplateSelector x:Key="DiscoveryRowTemplateSelector"
                                            StandardRowTemplate="{StaticResource StandardCatalogRowTemplate}"
                                            SpotlightRowTemplate="{StaticResource SpotlightCatalogRowTemplate}" />

    </UserControl.Resources>

    <Grid>
        <!-- DYNAMIC CATALOG ROWS - Now the root scrollable element for virtualization -->
        <ListView x:Name="DiscoveryRows" 
                  SelectionMode="None" 
                  IsItemClickEnabled="False"
                  IsTabStop="False"
                  ItemTemplateSelector="{StaticResource DiscoveryRowTemplateSelector}"
                  Padding="0,0,0,40">
            <ListView.Header>
                <local:HeroSectionControl x:Name="HeroControl" />
            </ListView.Header>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="MinWidth" Value="10"/>
                    <Setter Property="IsTabStop" Value="False"/>
                    <Setter Property="FocusVisualPrimaryThickness" Value="0"/>
                    <Setter Property="FocusVisualSecondaryThickness" Value="0"/>
                    <Setter Property="Control.Background" Value="Transparent"/>
                    <Setter Property="Control.BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListViewItem">
                                <ContentPresenter ContentTemplate="{TemplateBinding ContentTemplate}" 
                                                  ContentTransitions="{TemplateBinding ContentTransitions}" 
                                                  Content="{TemplateBinding Content}" 
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</UserControl>
