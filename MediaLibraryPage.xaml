<Page
    x:Class="ModernIPTVPlayer.MediaLibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ModernIPTVPlayer"
    xmlns:controls="using:ModernIPTVPlayer.Controls"
    mc:Ignorable="d" 
    NavigationCacheMode="Enabled"
    Background="Transparent">

    <Page.Resources>
        <ThemeShadow x:Key="SharedShadow"/>
    </Page.Resources>

    <Grid>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="AdaptiveStates">
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1100" />
                    </VisualState.StateTriggers>
                </VisualState>
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainSplitView.DisplayMode" Value="Overlay"/>
                        <Setter Target="MainSplitView.IsPaneOpen" Value="False"/>
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- Dynamic Backdrop -->
        <controls:DynamicBackdrop x:Name="BackdropControl" Grid.ColumnSpan="2"/>

        <!-- Vignette -->
        <Rectangle Fill="#15000000" IsHitTestVisible="False" Grid.ColumnSpan="2"/>

        <SplitView x:Name="MainSplitView"
                   DisplayMode="Overlay"
                   IsPaneOpen="False"
                   CompactPaneLength="0"
                   OpenPaneLength="320"
                   PaneBackground="#0F131C"
                   Background="Transparent"
                   LightDismissOverlayMode="On">
            
            <!-- SIDEBAR (IPTV Library Mode) -->
            <SplitView.Pane>
                <Grid>
                    <Grid.Background>
                        <AcrylicBrush TintColor="#0F131C" TintOpacity="0.85" FallbackColor="#0F131C"/>
                    </Grid.Background>
                    
                    <Grid BorderBrush="#1FFFFFFF" BorderThickness="0,0,1,0" Padding="0,24,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
    
                        <!-- Title -->
                        <Grid Height="60" VerticalAlignment="Top" Padding="24,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="SidebarTitle" Text="KÜTÜPHANE" FontSize="26" FontWeight="ExtraBold" VerticalAlignment="Center" CharacterSpacing="50">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFFFFF" Offset="0"/>
                                        <GradientStop Color="#CCCCCC" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>

                            <Button Grid.Column="1" Click="SearchButton_Click" Background="Transparent" BorderThickness="0" Padding="8" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE721;" FontSize="18" Foreground="White" Opacity="0.7"/>
                            </Button>
                        </Grid>
    
                        <!-- Search -->
                        <Grid Grid.Row="1" Padding="20,12">
                            <Border x:Name="SearchPillBorder" CornerRadius="18" Background="#0AFFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" Height="36">
                                <Grid VerticalAlignment="Stretch" Background="Transparent">
                                    <FontIcon Glyph="&#xE721;" FontSize="13" Foreground="White" Opacity="0.5" 
                                              HorizontalAlignment="Left" VerticalAlignment="Center" 
                                              Margin="12,0,0,0" IsHitTestVisible="False"/>
                                    <TextBox x:Name="CategorySearchBox" 
                                             PlaceholderText="Kategori Ara..." 
                                             BorderThickness="0" Background="Transparent" 
                                             Foreground="White" PlaceholderForeground="#80FFFFFF" FontSize="13" 
                                             VerticalAlignment="Stretch" VerticalContentAlignment="Center"
                                             Padding="34,8,12,0"
                                             HorizontalAlignment="Stretch"
                                             TextChanged="CategorySearch_TextChanged"/> 
                                </Grid>
                            </Border>
                        </Grid>
    
                        <!-- Modern Category List with Selection Pill -->
                        <Grid Grid.Row="2" Margin="12,8">
                            <!-- Selection Lens Pill (Composition Controlled) -->
                            <Border x:Name="CategorySelectionPill" 
                                    Width="4" Height="20" 
                                    Background="{ThemeResource SystemAccentColor}" 
                                    CornerRadius="2"
                                    HorizontalAlignment="Left" 
                                    VerticalAlignment="Top"
                                    Opacity="0"
                                    Margin="0,0,0,0"
                                    Canvas.ZIndex="1"/>

                            <ListView x:Name="CategoryList"
                                      SelectionMode="Single" 
                                      ItemClick="CategoryListView_ItemClick" 
                                      IsItemClickEnabled="True"
                                      Padding="0"
                                      ScrollViewer.VerticalScrollBarVisibility="Hidden">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="CornerRadius" Value="8"/>
                                        <Setter Property="Margin" Value="4,2"/>
                                        <Setter Property="Padding" Value="16,8"/>
                                        <Setter Property="MinHeight" Value="40"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <Grid x:Name="Root" Background="Transparent" CornerRadius="8">
                                                        <VisualStateManager.VisualStateGroups>
                                                            <VisualStateGroup x:Name="CommonStates">
                                                                <VisualState x:Name="Normal"/>
                                                                <VisualState x:Name="PointerOver">
                                                                    <Storyboard>
                                                                        <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)" To="#10FFFFFF" Duration="0:0:0.15"/>
                                                                    </Storyboard>
                                                                </VisualState>
                                                                <VisualState x:Name="Selected">
                                                                    <Storyboard>
                                                                        <ColorAnimation Storyboard.TargetName="Root" Storyboard.TargetProperty="(Grid.Background).(SolidColorBrush.Color)" To="#18FFFFFF" Duration="0:0:0.15"/>
                                                                    </Storyboard>
                                                                </VisualState>
                                                            </VisualStateGroup>
                                                        </VisualStateManager.VisualStateGroups>
                                                        <ContentPresenter Padding="{TemplateBinding Padding}" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:LiveCategory">
                                        <TextBlock Text="{x:Bind CategoryName, Mode=OneWay}" FontSize="14" FontWeight="Medium" Opacity="0.85" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Grid>
            </SplitView.Pane>

            <!-- CONTENT AREA -->
            <SplitView.Content>
                <Grid Background="Transparent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Header -->
                        <RowDefinition Height="*"/>    <!-- Media Grid -->
                    </Grid.RowDefinitions>

                    <!-- HEADER (Refactored for true mathematical centering) -->
                    <Grid x:Name="PageHeader" Grid.Row="0" Padding="24,24,36,12" Canvas.ZIndex="10">
                        <!-- Sidebar Toggle (Left Aligned) -->
                        <Button x:Name="SidebarToggle" Click="ToggleSidebar_Click" Background="Transparent" BorderThickness="0" Width="48" Height="48" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE700;" FontSize="20" Foreground="White"/>
                        </Button>
                        
                        <!-- Center: Source Switcher (Absolute Center Alignment) -->
                        <Grid x:Name="HeaderSwitcherContainer" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <StackPanel x:Name="SourceSwitcherPanel" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" 
                                        Background="#15FFFFFF" Padding="4" CornerRadius="20" VerticalAlignment="Center">
                                
                                <RadioButton x:Name="SourceIPTV" Content="Kütüphanem" 
                                             Style="{StaticResource PillRadioButtonStyle}" 
                                             IsChecked="False" 
                                             Checked="Source_Checked" Tag="IPTV"/>
                                
                                <RadioButton x:Name="SourceStremio" Content="Stremio" 
                                             Style="{StaticResource PillRadioButtonStyle}" 
                                             IsChecked="True"
                                             Checked="Source_Checked" Tag="Stremio"/>
                            </StackPanel>
                        </Grid>

                        <!-- Right Actions & Indexing Progress -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="16">
                            <!-- Indexing Progress Pill -->
                            <Grid x:Name="IndexingProgressPill" Margin="0,0,16,0" Opacity="0" Visibility="Collapsed" Background="#15FFFFFF" CornerRadius="20" Padding="8,4,12,4" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressRing IsActive="True" Width="18" Height="18" Foreground="{ThemeResource SystemAccentColor}"/>
                                    <TextBlock Text="İndeksleniyor..." FontSize="12" FontWeight="Medium" VerticalAlignment="Center" Foreground="White" Opacity="0.8"/>
                                </StackPanel>
                            </Grid>

                            <Button x:Name="SearchButton" Click="SearchButton_Click" Background="Transparent" BorderThickness="0" Width="40" Height="40" Padding="0">
                                <FontIcon Glyph="&#xE721;" FontSize="16" Foreground="White" Opacity="0.8"/>
                            </Button>
                            <controls:DownloadStatusButton />
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="ViewportGrid" Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <Grid.Clip>
                            <RectangleGeometry Rect="0,0,5000,5000" x:Name="ViewportClip"/>
                        </Grid.Clip>

                        <!-- IPTV host: content starts below header mirror -->
                        <Grid x:Name="IptvViewportHost" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Invisible spacer that mirrors the real header height -->
                            <Grid x:Name="HeaderSpacer" Grid.Row="0" Opacity="0" IsHitTestVisible="False"/>

                            <controls:UnifiedMediaGrid x:Name="MediaGrid" 
                                                       Grid.Row="1"
                                                       Margin="0" 
                                                       Visibility="Visible" 
                                                       HorizontalAlignment="Stretch" 
                                                       VerticalAlignment="Stretch" 
                                                       Background="Transparent" 
                                                       ShowIptvBadge="False" />
                        </Grid>

                        <!-- Stremio host: no header spacer offset -->
                        <Grid x:Name="StremioViewportHost" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                            <controls:StremioDiscoveryControl x:Name="StremioControl"
                                                              Visibility="Visible" 
                                                              HorizontalAlignment="Stretch" 
                                                              VerticalAlignment="Stretch" 
                                                              Background="Transparent" 
                                                              ShowIptvBadge="False"/>
                        </Grid>
                    </Grid>
                    
                    <!-- Overlays -->
                    <Canvas x:Name="OverlayCanvas" Grid.Row="0" Grid.RowSpan="2">
                        <Rectangle x:Name="CinemaScrim" Fill="#FF000000" Opacity="0" Visibility="Collapsed" IsHitTestVisible="False" Canvas.ZIndex="0"/>
                        <controls:ExpandedCard x:Name="ActiveExpandedCard" Visibility="Collapsed" IsHitTestVisible="True" Canvas.ZIndex="1"/>
                    </Canvas>

                    <controls:SpotlightSearchControl x:Name="SpotlightSearch" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed" Canvas.ZIndex="999"/>
                    <controls:GenreSelectionOverlay x:Name="GenreOverlay" Grid.Row="0" Grid.RowSpan="2" Canvas.ZIndex="998"/>
                </Grid>
            </SplitView.Content>
        </SplitView>
    </Grid>
</Page>
